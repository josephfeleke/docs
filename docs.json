{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dolphy API",
  "description": "OpenAI-compatible API for uncensored chat, image generation, image editing, video, and motion-control.",
  "colors": {
    "primary": "#a855f7",
    "light": "#c084fc",
    "dark": "#7e22ce"
  },
  "favicon": "/favicon.svg",
  "api": {
    "openapi": ["https://dolphy.chat/api/v1/openapi.json"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "authentication", "pricing", "errors"]
          },
          {
            "group": "Endpoints",
            "pages": [
              "chat-completions",
              "image-generation",
              "image-edit",
              "video",
              "motion-control",
              "models",
              "openapi"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "webhooks",
              "test-mode",
              "cost-limits",
              "model-permissions"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Get an API key",
        "href": "https://dolphy.chat/settings/api-keys"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://dolphy.chat/login"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/dolphychat"
    }
  }
}
